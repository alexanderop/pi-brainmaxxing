{
  "name": "pi-brainmaxxing",
  "version": "0.1.3",
  "description": "🧠 Project-local persistent memory for Pi. A committed brain/ vault (Obsidian-compatible) with an auto-rebuilt wikilink index, session injection, secret-scanned writes, and a reflect/ruminate/meditate learning loop. Inspired by poteto/brainmaxxing, optimized for Pi.",
  "type": "module",
  "main": "src/extension/index.ts",
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "scripts": {
    "check": "biome check --write --error-on-warnings . && tsc --noEmit",
    "lint": "biome lint --error-on-warnings src test",
    "fmt": "biome format --write src test",
    "pi": "pi --no-extensions -e .",
    "test": "vitest run",
    "verify": "pnpm run check && pnpm run test"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "memory",
    "persistent-memory",
    "brain",
    "obsidian",
    "learning-loop",
    "brainmaxxing",
    "agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexanderop/pi-brainmaxxing.git"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@earendil-works/pi-ai": "0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@types/node": "24.12.4",
    "typebox": "1.1.38",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
